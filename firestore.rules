rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Role helpers
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sparkodon61@gmail.com' ||
        request.auth.token.email == 'info.dar.arkbytes@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'super-admin')
      );
    }
    function hasRole(role, scId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData(request.auth.uid).role == role && 
             (scId == null || getUserData(request.auth.uid).schoolId == scId);
    }
    function isSchoolAdmin(scId) { return isSuperAdmin() || hasRole('school-admin', scId); }

    // 1. Schools
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create, delete: if isSuperAdmin();
      allow update: if isSchoolAdmin(schoolId);

      match /{allSubcollections=**} {
        allow read, write: if isSchoolAdmin(schoolId) || isSuperAdmin();
      }
    }

    // 2. Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && incoming().role in ['super-admin', 'school-admin', 'teacher', 'student', 'parent'])
      );
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // 3. Global Stats & Results
    match /stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
